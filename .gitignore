# IA (materia) - .gitignore pensado para repos livianos
# Enfoque: ignorar entornos, caches, datasets, modelos/pesos, checkpoints, vectordb y archivos grandes generados.

vectordb/
chroma.sqlite3

############################
# SO / IDE
############################
.DS_Store
Thumbs.db

.vscode/
.idea/

############################
# Python
############################
__pycache__/
*.py[cod]
*.pyd

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

dist/
build/
*.egg-info/

############################
# Entornos
############################
.venv/
venv/
ENV/
env/

############################
# Jupyter / IPython
############################
.ipynb_checkpoints/
profile_default/
ipython_config.py

############################
# Datos, salidas y artefactos pesados
############################
# Datasets crudos / procesados
data/
dataset/
datasets/**
!datasets/*.py
!datasets/*.jsonl
raw/
# corpus/processed/ se regenera en Colab, pero permitimos 2 archivos de identidad
4-RAG/corpus/processed/chunks.jsonl
4-RAG/corpus/processed/chunks.jsonl.bak
4-RAG/corpus/processed/*.jsonl
4-RAG/corpus/processed/*.npy
4-RAG/corpus/processed/*.npz
downloads/
prerender/

# Permitir la identidad del corpus (inyectada en el system prompt)
!4-RAG/corpus/processed/MANIFIESTO.md
!4-RAG/corpus/processed/AUTORES.md

# Resultados/outputs típicos
outputs/
output/
results/
runs/
logs/
log/
4-RAG/src/evaluation/results.json
4-RAG/src/evaluation/test_bank.json
4-RAG/results/

# Cachés de herramientas ML
.cache/
cache/
wandb/
mlruns/
lightning_logs/
tensorboard/
tfevents/
events.out.tfevents.*

# Checkpoints / pesos / modelos
checkpoints/
checkpoint/
ckpt/
*.ckpt
*.pt
*.pth
*.onnx
*.tflite
*.pb
*.h5
*.hdf5
*.pkl
*.joblib
*.npz
*.npy
*.safetensors

# Modelos/tokenizers de HuggingFace (descargados)
**/models/**
**/model/**
**/hf_cache/**

############################
# Frontend / Node (por si el LLM/demo usa web)
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/

############################
# Pygame / multimedia
############################
# Archivos temporales/exportados
*.mp4
*.mov
*.avi
*.mkv
*.gif
*.psd
*.aseprite

############################
# PDFs y docs pesados
############################
# Si querés versionar PDFs, borrá estas reglas.
*.pdf

############################
# Secretos
############################
.env
.env.*
*.pem
*.key
*secret*
*token*

############################
# Mantener ejemplos livianos
############################
# Permitir assets del juego (imágenes/audio) aunque sean binarios.
!pygames/assets/**
# Permitir el dataset chico del juego (si lo usan para entrenar algo simple)
!pygames/datos_mlp.csv
